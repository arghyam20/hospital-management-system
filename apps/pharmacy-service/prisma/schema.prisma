datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Medicine {
  id              String         @id @default(uuid())
  name            String         @unique
  genericName     String?
  manufacturer    String?
  description     String?
  unitPrice       Float
  requiresPrescription Boolean   @default(false)
  inventory       Inventory?
  prescriptions   PrescriptionItem[]
  dispensations   DispensationItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Inventory {
  id              String   @id @default(uuid())
  medicineId      String   @unique
  medicine        Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  quantity        Int      @default(0)
  reorderLevel    Int      @default(10)
  batchNumber     String?
  expiryDate      DateTime?
  supplier        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Prescription {
  id            String             @id @default(uuid())
  patientId     String
  doctorId      String
  appointmentId String?
  notes         String?
  status        String             @default("PENDING") // PENDING, DISPENSED, CANCELLED
  items         PrescriptionItem[]
  dispensation  Dispensation?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  dosage         String       // e.g., "500mg"
  frequency      String       // e.g., "Twice a day"
  duration       Int          // e.g., 7 (days)
  quantity       Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Dispensation {
  id             String             @id @default(uuid())
  prescriptionId String             @unique
  prescription   Prescription       @relation(fields: [prescriptionId], references: [id])
  pharmacistId   String
  dispensedDate  DateTime           @default(now())
  notes          String?
  items          DispensationItem[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model DispensationItem {
  id             String       @id @default(uuid())
  dispensationId String
  dispensation   Dispensation @relation(fields: [dispensationId], references: [id], onDelete: Cascade)
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  quantity       Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
